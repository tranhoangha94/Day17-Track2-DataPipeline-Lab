# Day 17 lab runs ZERO-KEY by default — you do not need to fill anything in.
# These are only for the OPTIONAL extension exercises.

# Extension 2 (real embeddings): pick a local model, no key needed.
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Extension (real LLM extraction for the KG bonus): only if you swap the
# deterministic extractor in pipeline/kg.py for an LLM. Any provider works.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-5.4-nano

# Gemini (compare_embed_models.py — semantic decontamination judge)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# EMBED_MODEL_A=exact
# EMBED_MODEL_B=gemini-3.1-flash-lite
